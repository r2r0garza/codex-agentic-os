# Loopback base URL of the codex-agentic-os read-only HTTP API
# (`codex-agentic-os api serve --port 8080`). Read server-side only by
# the dashboard's `/api/v1/*` proxy routes, which exist because the
# dashboard and the API run on different origins and a direct
# browser-side fetch would be blocked by CORS.
API_BASE_URL=http://127.0.0.1:8080
